# ═══════════════════════════════════════
#       ULTRATICKET BOT - CONFIGURACIÓN
# ═══════════════════════════════════════

# TOKEN del bot de Discord (Discord Developer Portal)
DISCORD_TOKEN=tu_token_aqui

# ID de la aplicación Discord
CLIENT_ID=tu_client_id_aqui

# Secret de la aplicación (para OAuth2 del dashboard)
CLIENT_SECRET=tu_client_secret_aqui

# ── DASHBOARD ──────────────────────────
# Puerto del dashboard web
DASHBOARD_PORT=3000

# URL donde estará el dashboard (cambia en producción)
DASHBOARD_URL=http://localhost:3000

# Clave secreta para sesiones (genera una aleatoria)
SESSION_SECRET=cambia_esto_por_una_clave_muy_segura_aleatoria

# ── BASE DE DATOS ──────────────────────
# Ruta a la base de datos SQLite
DATABASE_PATH=./data/tickets.db

# ── TRANSCRIPCIONES ────────────────────
# Carpeta donde guardar transcripciones
TRANSCRIPTS_PATH=./data/transcripts
